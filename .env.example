# ── ACD-Env — Environment Variables ──────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# In HuggingFace Spaces, set these as Space Secrets (Settings → Variables and secrets).
#
#   cp .env.example .env

# ── Hackathon-required variables ──────────────────────────────────────────────

# OpenAI-compatible API base URL (default shown — works with HF Inference API)
API_BASE_URL=https://api-inference.huggingface.co/v1/

# Model to use via the API (default shown)
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# HuggingFace token — NO default, must be set to enable LLM reasoning
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# Optional: only needed if using from_docker_image()
# LOCAL_IMAGE_NAME=

# ── Server config (optional) ──────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=7860
# LOG_LEVEL=info
